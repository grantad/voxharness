# VoxHarness Configuration
# Copy to .env and fill in your API keys

# LLM Provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6-20250514

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ElevenLabs TTS
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Whisper STT
WHISPER_MODEL=base.en
WHISPER_COMPUTE_TYPE=int8

# Server
WS_HOST=127.0.0.1
WS_PORT=8765

# VAD
VAD_THRESHOLD=0.5
SILENCE_DURATION_MS=400

# Listen mode: "wake_word", "push_to_talk", or "always_on"
LISTEN_MODE=wake_word

# Wake word: "hey_jarvis_v0.1", "alexa_v0.1", "hey_mycroft_v0.1"
WAKE_WORD=hey_jarvis_v0.1
WAKE_WORD_THRESHOLD=0.5
